# ─── Ciclo do Agente ──────────────────────────────────────────────────────────
BIDRADAR_INTERVAL_HOURS=6
BIDRADAR_DB_PATH=data/licitacoes.db

# ─── Scrapers habilitados ─────────────────────────────────────────────────────
BIDRADAR_ENABLE_COMPRASNET=false
BIDRADAR_ENABLE_BLL=false
# ConLicitação requer credenciais no Secret Manager — manter false até disponível
BIDRADAR_ENABLE_CONLICITACAO=false

# ─── PNCP ─────────────────────────────────────────────────────────────────────
# Códigos de modalidade da Lei 14.133 (deixar vazio para usar todos)
# BIDRADAR_PNCP_MODALIDADES=8,1,3,6,4

# ─── GCP — projeto principal (BigQuery, Pub/Sub, Firestore) ───────────────────
BIDRADAR_GCP_PROJECT_ID=creattive-licitacoes-dev
BIDRADAR_BQ_DATASET=licitacoes
BIDRADAR_BQ_TABLE=editais
BIDRADAR_PUBSUB_TOPIC=coleta-editais

# ─── Vertex AI + Google ADK ───────────────────────────────────────────────────
BIDRADAR_LLM_PROVIDER=vertex_gemini
BIDRADAR_VERTEX_PROJECT_ID=creattive-licitacoes-dev
BIDRADAR_VERTEX_LOCATION=us-central1
BIDRADAR_VERTEX_MODEL=gemini-2.5-pro

# Obrigatório para o Google ADK usar Vertex AI em vez da Gemini API pública
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=creattive-licitacoes-dev
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Credenciais ──────────────────────────────────────────────────────────────
# Caminho para o service account JSON (relativo à raiz do projeto)
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
