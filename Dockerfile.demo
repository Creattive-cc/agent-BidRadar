# Dockerfile da DEMO (Streamlit) — leve, para Cloud Run.
# Não substitui o Dockerfile de produção (FastAPI). Use com -f Dockerfile.demo.
FROM python:3.12-slim

# uv (Astral) para instalar dependências de forma rápida e reprodutível
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# 1) Dependências (camada cacheável)
COPY requirements-demo.txt ./
RUN uv pip install --system --no-cache -r requirements-demo.txt

# 2) Código do agente + app de demo
COPY agent ./agent
COPY company_profile ./company_profile
COPY streamlit_app.py ./
COPY .streamlit ./.streamlit

# Demo usa só o PNCP (API pública); scrapers de navegador desligados.
ENV BIDRADAR_ENABLE_BLL=false \
    BIDRADAR_ENABLE_CONLICITACAO=false \
    BIDRADAR_ENABLE_COMPRASNET=true \
    BIDRADAR_LLM_PROVIDER=heuristic

# Cloud Run injeta a porta em $PORT (default 8080).
ENV PORT=8080
EXPOSE 8080

# shell form para expandir $PORT
CMD streamlit run streamlit_app.py \
    --server.port=$PORT \
    --server.address=0.0.0.0 \
    --server.headless=true \
    --browser.gatherUsageStats=false
